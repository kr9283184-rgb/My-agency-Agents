# Email (SMTP) - Reuses same config as client-outreach
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=onboarding@example.com
SMTP_FROM_NAME="Client Onboarding Team"

# Path to client-outreach database (where won deals live)
OUTREACH_DB_PATH=../client-outreach\ team/output/outreach.db

# Onboarding output directory
ONBOARDING_OUTPUT_DIR=output
