# LLM Provider (Ollama - open source, runs locally)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Outreach Config
OUTREACH_OUTPUT_DIR=output
OUTREACH_DEFAULT_INDUSTRY="real estate agents"
OUTREACH_DEFAULT_LOCATION="Austin, TX"
OUTREACH_DEFAULT_MAX_LEADS=10

# Email (SMTP) - Open source, use any SMTP server
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=sales@example.com
SMTP_FROM_NAME="Sales Team"

# CalDAV Calendar (open standard)
CALDAV_URL=
CALDAV_USER=
CALDAV_PASSWORD=

# Rate Limiting (messages per hour per channel)
RATE_LIMIT_EMAIL=10
RATE_LIMIT_WHATSAPP=5
RATE_LIMIT_LINKEDIN=3
RATE_LIMIT_FACEBOOK=3
RATE_LIMIT_TWITTER=5
